# Database
DATABASE_URL="mysql://user:password@localhost:3306/blog"

# Site URL（服务端运行时使用，用于 OAuth 回调、sitemap 和 SEO）
SITE_URL="http://localhost:3000"

# Public Site URL（可选，仅当前端代码需要公开站点地址时使用）
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Admin Password (管理后台密码)
ADMIN_PASSWORD="admin123"

# Cookie Secure (HTTP 部署设为 false，HTTPS 部署设为 true)
COOKIE_SECURE="false"

# Cookie 签名密钥（生产环境请设置为长随机字符串）
AUTH_SECRET="replace-with-a-long-random-secret"

# GitHub OAuth（评论登录）
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
